{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for AI Chat App",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/database/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "postgres": "^3.4.3",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "dotenv": "^16.3.1",
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.28.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
